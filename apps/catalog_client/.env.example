# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=file_stats
POSTGRES_USER=file_stats
POSTGRES_PASSWORD=file_stats

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Celery ---
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2

# --- Внешнее API каталога файлов ---
EXTERNAL_API_BASE_URL=https://example.com
EXTERNAL_API_CANDIDATE_ID=my-candidate-id
# Максимум запросов в секунду к внешнему API (самоограничение, чтобы не словить 429/403)
EXTERNAL_API_RATE_LIMIT_PER_SECOND=2

# --- Приложение ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

# Таймзона для отображения времени старта скачивания
DISPLAY_TZ=Asia/Novosibirsk
